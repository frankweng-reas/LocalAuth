# Database
DATABASE_URL="postgresql://user:password@localhost:5432/localauth"

# JWT Configuration
JWT_SECRET=your-secret-key-here
# Access token 有效期（預設 1h），格式: 60s, 15m, 1h, 7d
JWT_ACCESS_EXPIRES_IN=1h
# Refresh token 有效期（預設 7d）
JWT_REFRESH_EXPIRES_IN=7d

# Application
PORT=4000
# 寄信連結（驗證 Email、重設密碼）的基底網址。若與 NeuroSme 等前端整合，應設為前端網址
# 開發：http://localhost:5173  正式：https://your-app.example.com
BASE_URL=http://localhost:5173

# AD Integration (optional)
AD_ENABLED=false
# AD_URL=ldap://ad.company.com
# AD_BASE_DN=DC=company,DC=com
# AD_BIND_DN=CN=service,OU=Users
# AD_BIND_PASSWORD=xxx

# Email Service（註冊驗證、忘記密碼皆需寄信）
# 選項: 'resend' | 'smtp' | 'console'
# ⚠️ console = 僅輸出到 log，不實際寄信！要寄信請改用 resend 或 smtp
EMAIL_PROVIDER=console
# Resend API Key (從 https://resend.com 取得，EMAIL_PROVIDER=resend 時必填)
RESEND_API_KEY=re_your_api_key_here
# 寄件者 email
EMAIL_FROM=noreply@yourdomain.com

# SMTP 設定（EMAIL_PROVIDER=smtp 時使用，支援 Gmail SMTP Relay）
# SMTP_HOST=smtp-relay.gmail.com
# SMTP_PORT=587
# SMTP_USER=developer@reas.com.tw
# SMTP_PASS=your-app-password
# EMAIL_FROM="Neurosme AI" <neurosme@reas.com.tw>

# 驗證郵件內容自訂（選填，{{name}} 會替換為用戶名稱，含空格需加引號）
# EMAIL_VERIFY_SUBJECT="歡迎加入 Neurosme AI - 請驗證您的 Email"
# EMAIL_VERIFY_APP_NAME="Neurosme AI"
# EMAIL_VERIFY_GREETING="Hi {{name}}，歡迎加入 Neurosme AI！"
# EMAIL_VERIFY_BODY="感謝您註冊 Neurosme AI！請點擊下方按鈕完成 Email 驗證，即可開始使用。"
# EMAIL_VERIFY_BUTTON="立即驗證 Email"
# EMAIL_VERIFY_FOOTER="若您未註冊 Neurosme AI，請忽略此郵件。"
