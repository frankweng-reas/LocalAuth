# =============================================================================
# LocalAuth 開發人員設定參考
#
# 三種模式：
#   DEPLOY_MODE=saas   → SaaS 正式環境（email 驗證開啟、允許自助註冊）
#   DEPLOY_MODE=onprem → On-Prem 環境（email 關閉、禁止自助註冊）
#   DEPLOY_MODE=dev    → 本機開發（以下方個別變數為準）
#
# 快速切換：
#   cp .env.saas .env    → 切換為 SaaS 模式
#   cp .env.onprem .env  → 切換為 On-Prem 模式
#
# 注意：JWT_SECRET 與 ADMIN_API_KEY 必須與 NeuroSme backend/.env 對齊
# =============================================================================

# -----------------------------------------------------------------------------
# 模式控制（最重要的一行，決定下方三個開關的預設值）
# -----------------------------------------------------------------------------
# DEPLOY_MODE=saas    → REQUIRE_EMAIL_VERIFICATION=true,  REGISTRATION_DISABLED=false, FORGOT_PASSWORD_ENABLED=true
# DEPLOY_MODE=onprem  → REQUIRE_EMAIL_VERIFICATION=false, REGISTRATION_DISABLED=true,  FORGOT_PASSWORD_ENABLED=false
# DEPLOY_MODE=dev     → 以下方個別設定為準
DEPLOY_MODE=dev

# -----------------------------------------------------------------------------
# 資料庫（docker-compose 對外 port 5433；須與 POSTGRES_* 密碼一致）
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_DB=localauth
# DATABASE_URL 僅供本機直連 DB 除錯用；docker-compose 環境不需設定（由 compose 自動拼出）
DATABASE_URL="postgresql://postgres:your-db-password-here@localhost:5433/localauth"

# -----------------------------------------------------------------------------
# JWT（必須與 NeuroSme backend/.env 的 JWT_SECRET 完全相同）
# 產生：openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-here
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# 應用程式
# -----------------------------------------------------------------------------
PORT=4000
# 驗證信／重設密碼信中的連結網址（啟用 email 時必填）
# SaaS：https://your-app.com  /  On-Prem：客戶對外網址（不啟用 email 時可留空）
BASE_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Admin API 金鑰（保護 /admin/* 端點）
# NeuroSme backend 呼叫時需帶 x-admin-api-key header
# 必須與 NeuroSme backend/.env 的 LOCALAUTH_ADMIN_API_KEY 相同
# 產生：openssl rand -hex 32
# -----------------------------------------------------------------------------
ADMIN_API_KEY=your-admin-api-key-here

# -----------------------------------------------------------------------------
# 預設管理員帳號（首次啟動且 DB 無 user 時自動建立）
# On-Prem 用：IT 人員首次登入後請立即修改密碼
# SaaS / 開發：通常不需要，DB 有資料後自動跳過
# -----------------------------------------------------------------------------
DEFAULT_ADMIN_EMAIL=admin@local.dev
DEFAULT_ADMIN_PASSWORD=Admin1234!

# -----------------------------------------------------------------------------
# 帳號政策（DEPLOY_MODE=dev 時個別生效；onprem/saas 時由程式自動套用，無需設定）
# -----------------------------------------------------------------------------
REQUIRE_EMAIL_VERIFICATION=true
REGISTRATION_DISABLED=false
FORGOT_PASSWORD_ENABLED=true

# -----------------------------------------------------------------------------
# Email（SaaS / 有 SMTP 的 on-prem 才需設定）
# EMAIL_PROVIDER 選項：smtp | console（console = 僅印 log，不實際寄信）
# On-Prem 預設 console，DEPLOY_MODE=onprem 時 email 功能關閉，以下設定不生效
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=console

# SMTP 設定
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="Neurosme AI <no-reply@your-domain.com>"

# -----------------------------------------------------------------------------
# 驗證信內容（SaaS 或啟用 email 的 on-prem 才需設定；{{name}} 會替換為用戶名稱）
# -----------------------------------------------------------------------------
# EMAIL_VERIFY_SUBJECT="歡迎加入 Neurosme AI - 請驗證您的 Email"
# EMAIL_VERIFY_APP_NAME="Neurosme AI"
# EMAIL_VERIFY_GREETING="Hi {{name}}，歡迎加入 Neurosme AI！"
# EMAIL_VERIFY_BODY="感謝您註冊 Neurosme AI！請點擊下方按鈕完成 Email 驗證，即可開始使用。"
# EMAIL_VERIFY_BUTTON="立即驗證 Email"
# EMAIL_VERIFY_FOOTER="若您未註冊 Neurosme AI，請忽略此郵件。"

# -----------------------------------------------------------------------------
# AD 整合（預留，目前未實作）
# -----------------------------------------------------------------------------
AD_ENABLED=false
# AD_URL=ldap://ad.company.com
# AD_BASE_DN=DC=company,DC=com
# AD_BIND_DN=CN=service,OU=Users
# AD_BIND_PASSWORD=xxx
